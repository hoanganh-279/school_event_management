@model IEnumerable<shcool_event_management.Models.EVENT>
@{
    ViewBag.Title      = "Khám phá Sự kiện";
    ViewBag.ActivePage = "home";
    Layout = "~/Views/Shared/_LayoutUsers.cshtml";
}

@* ── HERO (render qua section để Layout đặt đúng vị trí) ── *@
@section Hero {
<section class="ce-hero">
    <div class="container position-relative">
        <div class="row">
            <div class="col-lg-8">
                <div class="ce-hero__eyebrow">
                    <span class="material-symbols-outlined" style="font-size:13px">celebration</span>
                    Trường Đại học ABC · Năm học 2025–2026
                </div>
                <h1 class="ce-hero__title">
                    Khám phá &amp;<br />tham gia sự kiện<br />campus của bạn
                </h1>
                <p class="ce-hero__sub">
                    Tìm kiếm hàng trăm sự kiện học thuật, thể thao, văn hóa và workshop đang chờ bạn tham gia.
                </p>
                <div class="ce-hero__search">
                    <span class="material-symbols-outlined si">search</span>
                    <input type="search" id="hero-search" placeholder="Tìm sự kiện, CLB, workshop…" />
                    <button class="ce-hero__search-btn" type="button">Tìm kiếm</button>
                </div>
                <div class="ce-hero__stats">
                    <div class="ce-hero__stat">
                        <div>
                            <div class="ce-hero__stat-val" id="cnt-ev">@(Model?.Count() ?? 0)</div>
                            <div style="font-size:.73rem;opacity:.8">Sự kiện</div>
                        </div>
                    </div>
                    <div class="ce-hero__sep"></div>
                    <div class="ce-hero__stat">
                        <div>
                            <div class="ce-hero__stat-val" id="cnt-sv">0</div>
                            <div style="font-size:.73rem;opacity:.8">Sinh viên</div>
                        </div>
                    </div>
                    <div class="ce-hero__sep"></div>
                    <div class="ce-hero__stat">
                        <div>
                            <div class="ce-hero__stat-val" id="cnt-clb">0</div>
                            <div style="font-size:.73rem;opacity:.8">CLB &amp; Nhóm</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
}

@* ── BODY: container + sidebar + cards ── *@
<div class="container py-4">
    <div class="row g-4">

        @* Sidebar filter (desktop) *@
        <div class="col-lg-3 d-none d-lg-block">
            <div class="ce-filter-sidebar">
                <div class="ce-filter-title">Bộ lọc</div>

                <div class="ce-filter-group">
                    <div class="ce-filter-group__label">Viện / Khoa</div>
                    <label class="ce-filter-check">
                        <input type="checkbox" class="check-all" checked /> Tất cả
                    </label>
                    @if (ViewBag.ListVien != null)
                    {
                        foreach (var vien in ViewBag.ListVien)
                        {
                            <label class="ce-filter-check">
                                <input type="checkbox" class="check-item" value="@vien.MaVien" />
                                @vien.TenVien
                            </label>
                        }
                    }
                </div>

                <div class="ce-filter-hr"></div>

                <div class="ce-filter-group">
                    <div class="ce-filter-group__label">Danh mục</div>
                    <label class="ce-filter-check">
                        <input type="checkbox" class="check-all" checked /> Tất cả
                    </label>
                    @if (ViewBag.DanhMucs != null)
                    {
                        foreach (var dm in ViewBag.DanhMucs)
                        {
                            <label class="ce-filter-check">
                                <input type="checkbox" class="check-item" value="@dm.MaDanhMuc" />
                                @dm.TenDanhMuc
                            </label>
                        }
                    }
                </div>

                <div class="ce-filter-hr"></div>

                <div class="ce-filter-group">
                    <div class="ce-filter-group__label">Thời gian</div>
                    <label class="ce-filter-check"><input type="radio" name="time-filter" checked /> Tất cả</label>
                    <label class="ce-filter-check"><input type="radio" name="time-filter" /> Hôm nay</label>
                    <label class="ce-filter-check"><input type="radio" name="time-filter" /> Tuần này</label>
                    <label class="ce-filter-check"><input type="radio" name="time-filter" /> Tháng này</label>
                </div>

                <div class="ce-filter-hr"></div>

                <div class="ce-filter-group">
                    <div class="ce-filter-group__label">Trạng thái</div>
                    <label class="ce-filter-check"><input type="checkbox" class="check-all" checked /> Tất cả</label>
                    <label class="ce-filter-check"><input type="checkbox" class="check-item" /> Còn chỗ</label>
                    <label class="ce-filter-check"><input type="checkbox" class="check-item" /> Sắp đầy</label>
                    <label class="ce-filter-check"><input type="checkbox" class="check-item" /> Miễn phí</label>
                </div>

                <div class="ce-filter-hr"></div>
                <button class="ce-btn ce-btn-ghost ce-btn-sm ce-btn-block" id="btn-clear-filter" type="button">
                    <span class="material-symbols-outlined">refresh</span> Xóa bộ lọc
                </button>
            </div>
        </div>

        @* Main column *@
        <div class="col-lg-9">

            @* Upcoming alert *@
            <div class="ce-upcoming mb-4 ce-reveal">
                <div class="ce-upcoming__icon">
                    <span class="material-symbols-outlined">notifications_active</span>
                </div>
                <div style="flex:1;min-width:0">
                    <div class="ce-upcoming__title">🎉 Khám phá sự kiện mới nhất của trường!</div>
                    <div class="ce-upcoming__sub">Đăng ký tham dự và nhận QR check-in tự động</div>
                </div>
                <a href="@Url.Action("Events","Users")" class="ce-btn ce-btn-primary ce-btn-sm d-none d-sm-flex">
                    Xem tất cả
                </a>
            </div>

            @* Filter chips theo DanhMuc *@
            <div class="ce-chips mb-4">
                <span class="ce-chip active" data-value="all">
                    <span class="material-symbols-outlined">apps</span> Tất cả
                </span>
                @if (ViewBag.DanhMucs != null)
                {
                    foreach (var dm in ViewBag.DanhMucs)
                    {
                        <span class="ce-chip" data-value="@dm.MaDanhMuc">
                            @if (!string.IsNullOrEmpty(dm.Icon))
                            {
                                <span class="material-symbols-outlined">@dm.Icon</span>
                            }
                            @dm.TenDanhMuc
                        </span>
                    }
                }
            </div>

            @* Sort row *@
            <div class="d-flex align-items-center justify-content-between gap-3 mb-4 flex-wrap">
                <h2 class="ce-section-title mb-0">Sự kiện sắp diễn ra</h2>
                <div class="d-flex align-items-center gap-2">
                    <span style="font-size:.78rem;color:var(--text-muted);white-space:nowrap;font-weight:600">Sắp xếp:</span>
                    <select class="ce-form-select" style="width:auto;height:34px;font-size:.78rem">
                        <option>Sắp diễn ra</option>
                        <option>Phổ biến nhất</option>
                        <option>Mới nhất</option>
                    </select>
                </div>
            </div>

            @* Event cards *@
            @if (Model != null && Model.Any())
            {
                <div class="row g-3" id="events-grid">
                    @foreach (var item in Model)
                    {
                        var conLai = item.SoLuongToiDa - item.SoLuongDaDangKy;
                        <div class="col-12 col-sm-6 col-xl-4 ce-reveal" data-category="@item.MaDanhMuc">
                            <a href="@Url.Action("EventDetail","Users", new { id = item.MaEvent })" class="ce-event-card">
                                <div class="ce-event-card__img">
                                    <div class="ce-event-card__img-placeholder">
                                        <span class="material-symbols-outlined">@(item.DanhMuc?.Icon ?? "event")</span>
                                    </div>
                                    <div class="ce-event-card__badges">
                                        <span class="ce-badge ce-badge-primary">
                                            @(item.DanhMuc?.TenDanhMuc ?? "Sự kiện")
                                        </span>
                                        @if (conLai <= 0)
                                        {
                                            <span class="ce-badge ce-badge-danger">Hết chỗ</span>
                                        }
                                        else if (conLai <= 10)
                                        {
                                            <span class="ce-badge ce-badge-warning">Sắp đầy</span>
                                        }
                                    </div>
                                    <button class="ce-event-card__save" type="button" onclick="event.preventDefault()">
                                        <span class="material-symbols-outlined">favorite_border</span>
                                    </button>
                                </div>
                                <div class="ce-event-card__body">
                                    <div class="ce-event-card__title">@item.TenEvent</div>
                                    <div class="ce-event-card__meta">
                                        <div class="ce-event-card__meta-row">
                                            <span class="material-symbols-outlined">calendar_today</span>
                                            @item.NgayBatDau.ToString("dd/MM/yyyy", new System.Globalization.CultureInfo("vi-VN"))
                                        </div>
                                        @if (item.NgayKetThuc.HasValue)
                                        {
                                            <div class="ce-event-card__meta-row">
                                                <span class="material-symbols-outlined">event_available</span>
                                                @item.NgayKetThuc.Value.ToString("dd/MM/yyyy", new System.Globalization.CultureInfo("vi-VN"))
                                            </div>
                                        }
                                        <div class="ce-event-card__meta-row">
                                            <span class="material-symbols-outlined">location_on</span>
                                            @(item.DiaDiem?.TenDiaDiem ?? "Chưa xác định")
                                        </div>
                                        <div class="ce-event-card__meta-row">
                                            <span class="material-symbols-outlined">group</span>
                                            @(item.Vien?.TenVien ?? @item.MaVien ?? "Ban tổ chức")
                                        </div>
                                    </div>
                                    <div class="ce-event-card__footer">
                                        <div class="ce-event-card__slots">
                                            <span class="material-symbols-outlined">group</span>
                                            @(item.SoLuongDaDangKy) / @(item.SoLuongToiDa) chỗ
                                        </div>
                                        <span class="ce-badge ce-badge-primary">
                                            @(item.GiaVe == null || item.GiaVe == 0 ? "Miễn phí" : String.Format("{0:N0}đ", item.GiaVe))
                                        </span>
                                    </div>
                                </div>
                            </a>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="ce-empty">
                    <span class="material-symbols-outlined">event_busy</span>
                    <div class="ce-empty__title">Chưa có sự kiện nào</div>
                    <div class="ce-empty__sub">Hiện tại chưa có sự kiện nào được đăng. Vui lòng quay lại sau.</div>
                </div>
            }

            <div class="text-center mt-5">
                <a href="@Url.Action("Events","Users")" class="ce-btn ce-btn-outline">
                    <span class="material-symbols-outlined">expand_more</span> Xem thêm sự kiện
                </a>
            </div>

        </div>@* /col-lg-9 *@
    </div>@* /row *@
</div>@* /container *@

@section scripts {
<script>
    document.addEventListener('DOMContentLoaded', function () {
        // Counter animation
        setTimeout(function () {
            if (typeof ceCountUp === 'function') {
                ceCountUp(document.getElementById('cnt-sv'),  8420);
                ceCountUp(document.getElementById('cnt-clb'), 47);
            }
        }, 300);

        // Chip filter (client-side theo MaDanhMuc)
        document.querySelectorAll('.ce-chip').forEach(function (chip) {
            chip.addEventListener('click', function () {
                document.querySelectorAll('.ce-chip').forEach(function (c) { c.classList.remove('active'); });
                chip.classList.add('active');
                var val = chip.dataset.value;
                document.querySelectorAll('#events-grid > [data-category]').forEach(function (card) {
                    card.style.display = (val === 'all' || card.dataset.category === val) ? '' : 'none';
                });
            });
        });

        // Sidebar checkbox: check-all toggle
        document.querySelectorAll('.ce-filter-group').forEach(function (group) {
            var allCb   = group.querySelector('.check-all');
            var items   = group.querySelectorAll('.check-item');
            if (!allCb) return;
            allCb.addEventListener('change', function () {
                if (this.checked) items.forEach(function (i) { i.checked = false; });
            });
            items.forEach(function (item) {
                item.addEventListener('change', function () {
                    if (this.checked) allCb.checked = false;
                    if (group.querySelectorAll('.check-item:checked').length === 0) allCb.checked = true;
                });
            });
        });

        // Clear filter
        var clearBtn = document.getElementById('btn-clear-filter');
        if (clearBtn) {
            clearBtn.addEventListener('click', function () {
                document.querySelectorAll('.check-item').forEach(function (i) { i.checked = false; });
                document.querySelectorAll('.check-all').forEach(function (i) { i.checked = true; });
                var first = document.querySelector('input[name="time-filter"]');
                if (first) first.checked = true;
            });
        }
    });
</script>
}
