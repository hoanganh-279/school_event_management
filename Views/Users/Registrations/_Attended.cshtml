@model List<shcool_event_management.Models.DangKySuKien>

<div class="ce-tab-pane" id="tab-attended">
    @if (Model == null || !Model.Any())
    {
        <div class="ce-empty text-center py-5">
            <span class="material-symbols-outlined" style="font-size:52px; opacity:.6;">history_edu</span>
            <div class="ce-empty__title mt-3">Chưa tham gia sự kiện nào</div>
            <p class="text-muted small">Hãy tham gia sự kiện để tích lũy kinh nghiệm nhé 🚀</p>
            <a href="@Url.Action("Events","Users")" class="ce-btn ce-btn-primary mt-3">
                Khám phá sự kiện
            </a>
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-3">
            @foreach (var dk in Model)
            {
                var ev = dk.EVENT;
                var soNgay = (DateTime.Today - ev.NgayBatDau.Date).Days;

                <div class="ce-card p-4 ce-hover-card attended-card">

                    <div class="d-flex gap-3 align-items-start">
                        <div class="ce-icon-box attended-icon">
                            <span class="material-symbols-outlined">verified</span>
                        </div>

                        <div class="flex-grow-1 min-w-0">
                            <div class="d-flex justify-content-between align-items-start gap-2 flex-wrap">
                                <div class="fw-bold text-truncate">@ev.TenEvent</div>
                                <span class="ce-badge ce-badge-success">Hoàn thành</span>
                            </div>
                            <hr />
                                <div class="mt-3 text-muted small">
                                    <div class="text-muted small mt-1"><span class="material-symbols-outlined" style="font-size:16px">calendar_month</span> Ngày bắt đầu: <strong>@ev.NgayBatDau.ToString("dd/MM/yyyy")</strong></div>
                                    <div class="text-muted small mt-1"><span class="material-symbols-outlined" style="font-size:16px">calendar_month</span> Đã diễn ra <strong>@soNgay ngày trước</strong></div>
                                </div>
                            </div>

                        </div>

                    <div class="d-flex gap-2 mt-4 pt-3 border-top">
                        <a href="@Url.Action("EventDetail","Users", new { id = ev.MaEvent })"
                           class="ce-btn ce-btn-sm ce-btn-ghost flex-grow-1">
                            <span class="material-symbols-outlined">visibility</span> Xem lại
                        </a>
                        <a href="@Url.Action("Events","Users")"
                           class="ce-btn ce-btn-sm ce-btn-primary flex-grow-1">
                            <span class="material-symbols-outlined">explore</span> Tìm sự kiện mới
                        </a>
                    </div>
                </div>
            }
        </div>
    }
</div>