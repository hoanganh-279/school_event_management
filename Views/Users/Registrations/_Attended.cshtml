@model List<shcool_event_management.Models.DangKySuKien>

<div class="ce-tab-pane" id="tab-attended">
    @if (Model == null || !Model.Any())
    {
        <div class="ce-empty text-center py-5">
            <span class="material-symbols-outlined" style="font-size:48px; opacity:.5;">history_edu</span>
            <div class="ce-empty__title mt-2">Chưa tham gia sự kiện nào</div>
            <p class="text-muted small">Hãy tham gia sự kiện để tích lũy trải nghiệm nhé 🚀</p>
            <a href="@Url.Action("Events","Users")" class="ce-btn ce-btn-primary mt-3">
                Khám phá sự kiện
            </a>
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-3">
            @foreach (var dk in Model)
            {
                var ev = dk.EVENT;
                var soNgay = (DateTime.Today - ev.NgayBatDau.Date).Days;

                <div class="ce-card p-3 ce-hover-card attended-card">

                    <div class="d-flex gap-3 align-items-start flex-wrap">

                        <!-- Icon -->
                        <div class="ce-icon-box-small attended-icon">
                            <span class="material-symbols-outlined">verified</span>
                        </div>

                        <!-- Nội dung -->
                        <div class="flex-grow-1" style="min-width:0">

                            <div class="fw-bold text-truncate">
                                @ev.TenEvent
                            </div>
                            <hr />
                            <div class="text-muted small mt-1">
                                Ngày Bắt Đầu: @ev.NgayBatDau.ToString("dd/MM/yyyy")
                            </div>

                            <div class="text-muted small">
                               Đã diễn ra @soNgay ngày trước
                            </div>

                        </div>

                        <!-- Badge -->
                        <span class="ce-badge ce-badge-success">
                            Hoàn thành
                        </span>

                    </div>

                    <!-- Action -->
                    <div class="d-flex gap-2 mt-3 pt-3 flex-wrap attended-actions">

                        <a href="@Url.Action("EventDetail","Users", new { id = ev.MaEvent })"
                           class="ce-btn ce-btn-sm ce-btn-ghost">
                            <span class="material-symbols-outlined" style="font-size:14px">visibility</span>
                            Xem lại
                        </a>

                        <a href="@Url.Action("Events","Users")"
                           class="ce-btn ce-btn-sm ce-btn-primary">
                            <span class="material-symbols-outlined" style="font-size:14px">explore</span>
                            Tìm sự kiện mới
                        </a>

                    </div>

                </div>
            }
        </div>
    }
</div>