@model List<shcool_event_management.Models.DangKySuKien>

@{
    var list = ViewBag.DaDangKy as List<shcool_event_management.Models.DangKySuKien>;
}

<div class="ce-tab-pane active" id="tab-upcoming">
    @if (list == null || !list.Any())
    {
        <div class="ce-empty text-center">
            <span class="material-symbols-outlined">event_upcoming</span>
            <div class="ce-empty__title">Chưa có sự kiện sắp tới</div>
            <a href="@Url.Action("Events","Users")" class="ce-btn ce-btn-primary mt-2">Khám phá ngay</a>
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-3">
            @foreach (var dk in list)
            {
                var ev = dk.EVENT;
                var soNgay = (ev.NgayBatDau.Date - DateTime.Today).Days;

                <div class="ce-card p-3 ce-hover-card">

                    <div class="d-flex gap-3 flex-wrap">
                        <div class="ce-icon-box">
                            <span class="material-symbols-outlined">
                                @(ev.DanhMuc?.Icon ?? "event")
                            </span>
                        </div>

                        <div class="flex-grow-1">

                            <div class="d-flex justify-content-between flex-wrap gap-2">

                                <div style="min-width:0">
                                    <div class="d-flex justify-content-between align-items-start gap-2 flex-wrap">
                                        <div class="fw-bold text-truncate">@ev.TenEvent</div>
                                        <span class="ce-badge ce-badge-success">Đã đăng ký</span>
                                    </div>
                                        <hr>
                                        <div class="text-muted small mt-1"> <span class="material-symbols-outlined" style="font-size:16px">calendar_month</span> Ngày Bắt Đầu: @ev.NgayBatDau.ToString("dd/MM/yyyy")</div>
                                        <div class="text-muted small mt-1"> <span class="material-symbols-outlined" style="font-size:16px">location_on</span> Địa điểm: @(ev.DiaDiem?.TenDiaDiem ?? "Chưa xác định")</div>
                                    </div>
                                    <div>
                                        @if (soNgay == 0)
                                        {
                                            <span class="ce-badge ce-badge-danger">🔥 Hôm nay</span>
                                        }
                                        else if (soNgay > 0)
                                        {
                                            <span class="ce-badge ce-badge-primary">Còn @soNgay ngày</span>
                                        }
                                    </div>

                                </div>

                            <div class="d-flex flex-wrap gap-2 mt-3 pt-2 border-top">

                                <a href="@Url.Action("EventDetail","Users", new { id = ev.MaEvent })"
                                   class="ce-btn ce-btn-ghost ce-btn-sm">
                                    <span class="material-symbols-outlined">info</span>Chi tiết
                                </a>

                                <button class="ce-btn ce-btn-ghost ce-btn-sm ms-auto text-danger"
                                        onclick="confirmHuy(@dk.MaEvent, '@ev.TenEvent')">
                                    Hủy
                                </button>

                            </div>

                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>