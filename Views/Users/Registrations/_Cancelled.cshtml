@model List<shcool_event_management.Models.DangKySuKien>

<div class="ce-tab-pane" id="tab-cancelled">
    @if (Model == null || !Model.Any())
    {
        <div class="ce-empty text-center py-5">
            <span class="material-symbols-outlined" style="font-size:48px; opacity:.5;">layers_clear</span>
            <div class="ce-empty__title mt-2">Danh sách trống</div>
            <p class="text-muted small">Bạn chưa hủy đăng ký sự kiện nào.</p>
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-3">
            @foreach (var dk in Model)
            {
                var ev = dk.EVENT;

                <div class="ce-card p-3 ce-hover-card cancelled-card">

                    <div class="d-flex gap-3 align-items-start flex-wrap">

                        <!-- Icon -->
                        <div class="ce-icon-box-small cancelled-icon">
                            <span class="material-symbols-outlined">event_busy</span>
                        </div>

                        <!-- Nội dung -->
                        <div class="flex-grow-1" style="min-width:0">
                            <div class="fw-bold text-truncate">
                                @ev.TenEvent
                            </div>
                            <hr>
                            <div class="text-muted small mt-1">
                                Ngày bắt đầu: @ev.NgayBatDau.ToString("dd/MM/yyyy")
                            </div>

                            <div class="text-muted small">
                                Hủy lúc: @dk.NgayDangKy.ToString("dd/MM/yyyy HH:mm")
                            </div>
                        </div>

                        <!-- Badge -->
                        <span class="ce-badge ce-badge-danger">Đã hủy</span>

                    </div>

                    <!-- Action -->
                    <div class="d-flex gap-2 mt-3 pt-3 flex-wrap cancelled-actions">

                        <a href="@Url.Action("EventDetail","Users", new { id = ev.MaEvent })"
                           class="ce-btn ce-btn-sm ce-btn-ghost">
                            <span class="material-symbols-outlined" style="font-size:14px">visibility</span>
                            Xem lại
                        </a>
                    </div>

                </div>
            }
        </div>
    }
</div>