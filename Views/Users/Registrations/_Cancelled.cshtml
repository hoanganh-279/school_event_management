@model List<shcool_event_management.Models.DangKySuKien>

<div class="ce-tab-pane" id="tab-cancelled">
    @if (Model == null || !Model.Any())
    {
        <div class="ce-empty text-center py-5">
            <span class="material-symbols-outlined" style="font-size:52px; opacity:.6;">layers_clear</span>
            <div class="ce-empty__title mt-3">Chưa có sự kiện bị hủy</div>
            <p class="text-muted small">Bạn chưa hủy đăng ký sự kiện nào.</p>
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-3">
            @foreach (var dk in Model)
            {
                var ev = dk.EVENT;

                <div class="ce-card p-4 ce-hover-card attended-card">

                    <div class="d-flex gap-3 align-items-start">
                        <!-- Icon -->
                        <div class="ce-icon-box cancelled-icon">
                            <span class="material-symbols-outlined">event_busy</span>
                        </div>

                        <!-- Nội dung -->
                        <div class="flex-grow-1 min-w-0">
                            <div class="d-flex justify-content-between align-items-start gap-2 flex-wrap">
                                <div class="fw-bold text-truncate">@ev.TenEvent</div>
                                <span class="ce-badge ce-badge-danger">Đã hủy</span>
                            </div>
                            <hr
                            <div class="mt-3 text-muted small">
                                <div class="text-muted small mt-1">
                                    <span class="material-symbols-outlined" style="font-size:16px">calendar_month</span>
                                    Ngày bắt đầu: @ev.NgayBatDau.ToString("dd/MM/yyyy")
                                </div>
                                <div class="text-muted small mt-1">
                                    <span class="material-symbols-outlined" style="font-size:16px">schedule</span>
                                    Hủy lúc: @dk.NgayDangKy.ToString("dd/MM/yyyy HH:mm")
                                </div>
                            </div>
                        </div>

                        <div class="d-flex flex-wrap gap-2 mt-3 pt-2 border-top">

                            <a href="@Url.Action("EventDetail","Users", new { id = ev.MaEvent })"
                               class="ce-btn ce-btn-ghost ce-btn-sm">
                                <span class="material-symbols-outlined">info</span>Chi tiết
                            </a>
                        </div>
                    </div>           
                </div>
            }
        </div>
    }
</div>