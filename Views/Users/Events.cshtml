@model IEnumerable<shcool_event_management.Models.EVENT>
@using System.Globalization

@{
    ViewBag.Title = "Sự kiện";
    ViewBag.ActivePage = "events";
    Layout = "~/Views/Shared/_LayoutUsers.cshtml";
}

<div class="container py-4">
    <div class="row g-4">

        <!-- Sidebar Filter -->
        @Html.Partial("Filter")

        <div class="col-lg-9">

            <!-- Upcoming Banner -->
            <div class="ce-upcoming mb-4 ce-reveal">
                <div class="ce-upcoming__icon">
                    <span class="material-symbols-outlined">notifications_active</span>
                </div>
                <div style="flex:1; min-width:0">
                    <div class="ce-upcoming__title">Khám phá hàng trăm sự kiện hấp dẫn đang chờ bạn</div>
                    <div class="ce-upcoming__sub">Đăng ký nhanh – Nhận mã QR check-in – Kết nối cộng đồng</div>
                </div>
                <a href="#" class="ce-btn ce-btn-primary ce-btn-sm d-none d-sm-flex">
                    Xem tất cả
                </a>
            </div>

            <!-- Chips Filter -->
            <div class="ce-chips mb-4">
                <span class="ce-chip active" data-value="all">
                    <span class="material-symbols-outlined">apps</span> Tất cả
                </span>

                @if (ViewBag.DanhMucs != null)
                {
                    foreach (var dm in ViewBag.DanhMucs)
                    {
                        <span class="ce-chip" data-value="@dm.MaDanhMuc">
                            @if (!string.IsNullOrEmpty(dm.Icon))
                            {
                                <span class="material-symbols-outlined">@dm.Icon</span>
                            }
                            @dm.TenDanhMuc
                        </span>
                    }
                }
            </div>

            <!-- Header + Sort -->
            <div class="d-flex align-items-center justify-content-between gap-3 mb-4 flex-wrap">
                <h2 class="ce-section-title mb-0">Danh sách sự kiện</h2>

                <div class="d-flex align-items-center gap-2">
                    <span style="font-size:.78rem; color:var(--text-muted); font-weight:600;">Sắp xếp theo:</span>
                    <select id="sort-select" class="ce-form-select" style="width:auto; height:38px; font-size:.82rem;">
                        <option value="newest">Mới nhất</option>
                        <option value="upcoming">Sắp diễn ra</option>
                        <option value="popular">Phổ biến nhất</option>
                    </select>
                </div>
            </div>

            <!-- Events Grid -->
            @if (Model != null && Model.Any())
            {
                <div class="row g-3" id="events-grid">
                    @foreach (var item in Model)
                    {
                        var conLai = item.SoLuongToiDa - item.SoLuongDaDangKy;
                        bool isSaved = ViewBag.SavedEventIds != null && ((List<int>)ViewBag.SavedEventIds).Contains(item.MaEvent);

                        <div class="col-12 col-sm-6 col-xl-4 ce-reveal" data-category="@item.MaDanhMuc">
                            <div class="ce-event-card">

                                <!-- Image + Badges -->
                                <div class="ce-event-card__img">
                                    <a href="@Url.Action("EventDetail","Users", new { id = item.MaEvent })">
                                        <div class="ce-event-card__img-placeholder">
                                            <span class="material-symbols-outlined">@(item.DanhMuc?.Icon ?? "event")</span>
                                        </div>
                                    </a>

                                    <div class="ce-event-card__badges">
                                        <span class="ce-badge" style="background-color: @(item.DanhMuc?.MauSac ?? "#3b82f6");">
                                            @item.DanhMuc.TenDanhMuc
                                        </span>
                                        @if (conLai == 0)
                                        {
                                        <span class="ce-badge ce-badge-danger">Hết chỗ</span>
                                        }
                                        else if (conLai <= 10)
                                        {
                                        <span class="ce-badge ce-badge-warning">Sắp đầy (Còn conLai chỗ)</span>
                                        }
                                        else
                                        {
                                        <span class="ce-badge ce-badge-success">Còn chỗ</span>
                                        }
                                    </div>

                                    <!-- Nút Lưu -->
                                    <button class="ce-event-card__save @(isSaved ? "saved" : "")"
                                            type="button"
                                            id="btn-favorite-@item.MaEvent"
                                            onclick="toggleFavorite(this, @item.MaEvent); event.preventDefault(); event.stopPropagation();">
                                        <span class="material-symbols-outlined">
                                            @(isSaved ? "favorite" : "favorite_border")
                                        </span>
                                    </button>
                                </div>

                                <!-- Body -->
                                <div class="ce-event-card__body">
                                    <h5 class="ce-event-card__title">
                                        <a href="@Url.Action("EventDetail","Users", new { id = item.MaEvent })" class="text-decoration-none">
                                            @item.TenEvent
                                        </a>
                                    </h5>

                                    <div class="ce-event-card__meta">
                                        <div class="ce-event-card__meta-row">
                                            <span class="material-symbols-outlined">calendar_today</span>
                                            @item.NgayBatDau.ToString("dddd, dd/MM/yyyy", new CultureInfo("vi-VN"))
                                        </div>
                                        @if (item.NgayKetThuc.HasValue)
                                        {
                                            <div class="ce-event-card__meta-row">
                                                <span class="material-symbols-outlined">event_busy</span>
                                                Đến @item.NgayKetThuc.Value.ToString("dd/MM/yyyy")
                                            </div>
                                        }
                                        <div class="ce-event-card__meta-row">
                                            <span class="material-symbols-outlined">location_on</span>
                                            @(item.DiaDiem?.TenDiaDiem ?? "Chưa xác định")
                                        </div>
                                    </div>

                                    <div class="ce-event-card__footer">
                                        <div class="ce-event-card__slots">
                                            <span class="material-symbols-outlined">group</span>
                                            @conLai / @item.SoLuongToiDa chỗ còn lại
                                        </div>
                                        <span class="ce-badge @(item.GiaVe == 0 ? "ce-badge-primary" : "ce-badge-info")">
                                            @(item.GiaVe == 0 || item.GiaVe == null ? "Miễn phí" : String.Format("{0:N0}đ", item.GiaVe))
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="ce-empty text-center py-5">
                    <span class="material-symbols-outlined display-1 text-muted">search_off</span>
                    <h4 class="mt-3">Không tìm thấy sự kiện nào</h4>
                    <p class="text-muted">Vui lòng thử thay đổi bộ lọc hoặc từ khóa tìm kiếm.</p>
                </div>
            }

        </div>
    </div>
</div>

@section scripts {
    <script src="~/Scripts/A-user-events.js"></script>
}