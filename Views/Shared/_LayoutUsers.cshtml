@* Views/Shared/_LayoutUsers.cshtml *@
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title – CampusEvents</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />

    <link href="@Url.Content("~/Content/campus-variables.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/campus-base.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/campus-navbar.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/campus-components.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/campus-pages.css")" rel="stylesheet" />

    @RenderSection("styles", required: false)
</head>
<body>

    @* ── NAVBAR ── *@
    <nav class="ce-navbar">
        <a href="@Url.Action("Index", "Users")" class="ce-navbar__brand">
            <div class="ce-navbar__logo">
                <span class="material-symbols-outlined">school</span>
            </div>
            <span class="ce-navbar__name">CampusEvents</span>
        </a>

        <div class="ce-navbar__search d-none d-md-block">
            <span class="material-symbols-outlined si">search</span>
            <input type="search" placeholder="Tìm kiếm sự kiện…" id="navbar-search" />
        </div>

        <div class="ce-navbar__nav">
            <a href="@Url.Action("Index",         "Users")" class="@(ViewBag.ActivePage == "home"          ? "active" : "")">
                <span class="material-symbols-outlined">home</span> Trang chủ
            </a>
            <a href="@Url.Action("Events",        "Users")" class="@(ViewBag.ActivePage == "events"        ? "active" : "")">
                <span class="material-symbols-outlined">event</span> Sự kiện
            </a>
            <a href="@Url.Action("Registrations", "Users")" class="@(ViewBag.ActivePage == "registrations" ? "active" : "")">
                <span class="material-symbols-outlined">assignment_turned_in</span> Đăng ký của tôi
            </a>
            <a href="@Url.Action("Schedule",      "Users")" class="@(ViewBag.ActivePage == "schedule"      ? "active" : "")">
                <span class="material-symbols-outlined">calendar_month</span> Lịch của tôi
            </a>
        </div>

        <div class="ce-navbar__actions">
            <button class="ce-navbar__icon-btn" data-action="toggle-theme" title="Đổi giao diện">
                <span class="material-symbols-outlined ce-theme-icon">light_mode</span>
            </button>
            <button class="ce-navbar__icon-btn d-none d-sm-flex" title="Thông báo"
                    onclick="ceOpenModal('modal-notif')">
                <span class="material-symbols-outlined">notifications</span>
                <span class="ce-notif-dot"></span>
            </button>
            <a href="@Url.Action("Registrations", "Users")" class="ce-navbar__avatar" title="Tài khoản">
                @{
                    var name = ViewBag.UserName as string ?? "SV";
                    var initials = name.Length >= 2 ? name.Substring(0, 2).ToUpper() : name.ToUpper();
                }
                @initials
            </a>
            <button class="ce-navbar__toggler" id="ce-nav-toggler" aria-label="Menu">
                <span class="material-symbols-outlined">menu</span>
            </button>
        </div>
    </nav>

    @* ── MOBILE MENU ── *@
    <div class="ce-mobile-menu" id="ce-mobile-menu">
        <div class="ce-mobile-menu__search">
            <span class="material-symbols-outlined si">search</span>
            <input type="search" placeholder="Tìm kiếm sự kiện…" />
        </div>
        <a href="@Url.Action("Index",         "Users")" class="@(ViewBag.ActivePage == "home"          ? "active" : "")">
            <span class="material-symbols-outlined">home</span> Trang chủ
        </a>
        <a href="@Url.Action("Events",        "Users")" class="@(ViewBag.ActivePage == "events"        ? "active" : "")">
            <span class="material-symbols-outlined">event</span> Sự kiện
        </a>
        <a href="@Url.Action("Registrations", "Users")" class="@(ViewBag.ActivePage == "registrations" ? "active" : "")">
            <span class="material-symbols-outlined">assignment_turned_in</span> Đăng ký của tôi
        </a>
        <a href="@Url.Action("Schedule",      "Users")" class="@(ViewBag.ActivePage == "schedule"      ? "active" : "")">
            <span class="material-symbols-outlined">calendar_month</span> Lịch của tôi
        </a>
    </div>

    @* ── NOTIFICATION MODAL ── *@
    <div class="ce-modal-overlay" id="modal-notif">
        <div class="ce-modal-box" style="max-width:370px">
            <div class="ce-modal-header">
                <h5>Thông báo</h5>
                <button class="ce-modal-close" onclick="ceCloseModal('modal-notif')">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            <div class="ce-modal-body">
                <div style="display:flex;gap:.75rem;padding:.75rem 0;border-bottom:1px solid var(--border)">
                    <div style="width:34px;height:34px;border-radius:50%;background:var(--primary-light);display:flex;align-items:center;justify-content:center;color:var(--primary);flex-shrink:0">
                        <span class="material-symbols-outlined" style="font-size:17px">notifications_active</span>
                    </div>
                    <div style="flex:1">
                        <div style="font-size:.85rem;font-weight:600;color:var(--text)">Tech Symposium – Còn 2 ngày!</div>
                        <div style="font-size:.75rem;color:var(--text-muted)">Thứ Sáu, 21/03 · Hội trường A</div>
                    </div>
                    <div style="font-size:.72rem;color:var(--text-light);white-space:nowrap">1 giờ trước</div>
                </div>
            </div>
            <div class="ce-modal-footer">
                <button class="ce-btn ce-btn-ghost ce-btn-sm" onclick="ceCloseModal('modal-notif')">Đóng</button>
                <a href="@Url.Action("Registrations","Users")" class="ce-btn ce-btn-primary ce-btn-sm">Xem tất cả</a>
            </div>
        </div>
    </div>

    @* ── PAGE WRAPPER ── *@
    <div class="ce-page-wrapper">
        <main class="ce-main">
            @RenderSection("Hero", required: false)

            @RenderBody()
        </main>

        <footer style="background:var(--surface);border-top:1px solid var(--border);padding:1.75rem 0;margin-top:2rem">
            <div class="container">
                <div class="row align-items-center g-3">
                    <div class="col-md-6">
                        <div class="d-flex align-items-center gap-2 mb-1">
                            <div style="width:26px;height:26px;background:var(--primary);border-radius:6px;display:flex;align-items:center;justify-content:center;color:#fff">
                                <span class="material-symbols-outlined" style="font-size:15px">school</span>
                            </div>
                            <span style="font-weight:700;font-size:.9rem">CampusEvents</span>
                        </div>
                        <p style="font-size:.78rem;color:var(--text-muted);margin:0">Cổng thông tin sự kiện sinh viên – Trường Đại học ABC</p>
                    </div>
                    <div class="col-md-6 text-md-end">
                        <p style="font-size:.75rem;color:var(--text-muted);margin:0">© 2025 CampusEvents · Tất cả quyền được bảo lưu</p>
                    </div>
                </div>
            </div>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="@Url.Content("~/Scripts/campus-app.js")"></script>
    @RenderSection("scripts", required: false)

</body>
</html>
