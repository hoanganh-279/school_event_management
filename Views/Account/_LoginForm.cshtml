
<div class="ce-auth-title">Chào mừng trở lại!</div>
<div class="ce-auth-sub">Đăng nhập bằng tài khoản sinh viên của bạn</div>

@using (Html.BeginForm("Login", "Account", FormMethod.Post))
{
    @Html.AntiForgeryToken()

    if (TempData["Error"] != null)
    {
        <div class="alert alert-danger" style="font-size: 0.85rem; padding: 0.75rem; border-radius: 8px; margin-bottom: 1rem;">
            <span class="material-symbols-outlined" style="font-size: 16px; vertical-align: text-bottom;">error</span>
            @TempData["Error"]
        </div>
    }
    <div class="mb-3">
        <label class="ce-form-label">Mã sinh viên / Email</label>
        <div class="ce-input-icon">
            <span class="material-symbols-outlined icon">badge</span>
            <input class="ce-form-control" name="username" type="text"
                   placeholder="SV2021001234 hoặc email@student.abc.edu.vn" />
        </div>
    </div>
    <div class="mb-2">
        <label class="ce-form-label">Mật khẩu</label>
        <div class="ce-input-icon">
            <span class="material-symbols-outlined icon">lock</span>
            <input class="ce-form-control" name="password" type="password"
                   id="pw-login" placeholder="••••••••"
                   style="padding-right:2.8rem" />
            <button type="button" onclick="cePwToggle('pw-login',this)"
                    style="position:absolute;right:.7rem;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:var(--text-muted)">
                <span class="material-symbols-outlined" style="font-size:17px">visibility</span>
            </button>
        </div>
    </div>
    <div class="d-flex justify-content-end mb-4">
        <a href="#" style="font-size:.78rem;color:var(--primary)">Quên mật khẩu?</a>
    </div>
    <button class="ce-btn ce-btn-primary ce-btn-block ce-btn-lg mb-3" type="submit">
        <span class="material-symbols-outlined">login</span> Đăng nhập
    </button>
}

<div class="ce-auth-divider">hoặc</div>
<button class="ce-btn ce-btn-ghost ce-btn-block ce-btn-lg" style="justify-content:center;gap:.6rem" type="button">
    <svg width="17" height="17" viewBox="0 0 48 48"><path fill="#EA4335" d="M24 9.5c3.5 0 6.6 1.2 9.1 3.2l6.8-6.8C35.7 2.3 30.2 0 24 0 14.6 0 6.6 5.5 2.8 13.5l7.9 6.1C12.5 13.2 17.8 9.5 24 9.5z" /><path fill="#4285F4" d="M46.5 24.5c0-1.6-.1-3.1-.4-4.5H24v8.5h12.7c-.6 2.9-2.3 5.3-4.8 7l7.6 5.9c4.5-4.1 7-10.2 7-16.9z" /><path fill="#FBBC05" d="M10.7 28.4A14.5 14.5 0 0 1 9.5 24c0-1.5.3-3 .7-4.4l-7.9-6.1A23.8 23.8 0 0 0 0 24c0 3.9.9 7.5 2.8 10.7l7.9-6.3z" /><path fill="#34A853" d="M24 48c6.2 0 11.4-2 15.2-5.5l-7.6-5.9c-2 1.4-4.7 2.2-7.6 2.2-6.2 0-11.5-3.7-13.3-9.9l-7.9 6.3C6.6 42.5 14.6 48 24 48z" /></svg>
    Tiếp tục với Google (SSO Trường)
</button>