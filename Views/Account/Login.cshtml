@* Views/Account/Login.cshtml — Đăng nhập / Đăng ký *@
@{
    ViewBag.Title = "Đăng nhập";
    Layout = null; @* Không dùng _LayoutUsers vì auth có layout riêng *@
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title – CampusEvents</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />
    <link href="~/Content/campus-variables.css" rel="stylesheet" />
    <link href="~/Content/campus-base.css"      rel="stylesheet" />
    <link href="~/Content/campus-components.css" rel="stylesheet" />
    <link href="~/Content/campus-pages.css"     rel="stylesheet" />
</head>
<body>

@* Mobile topbar *@
<div style="display:flex;align-items:center;justify-content:space-between;padding:.875rem 1.25rem;background:var(--surface);border-bottom:1px solid var(--border);position:sticky;top:0;z-index:100"
     class="d-lg-none">
    <div style="display:flex;align-items:center;gap:.5rem">
        <div style="width:30px;height:30px;background:var(--primary);border-radius:6px;display:flex;align-items:center;justify-content:center;color:#fff">
            <span class="material-symbols-outlined" style="font-size:17px">school</span>
        </div>
        <span style="font-weight:800;font-size:.9rem">CampusEvents</span>
    </div>
    <button data-action="toggle-theme" style="background:none;border:none;cursor:pointer;color:var(--text-muted)">
        <span class="material-symbols-outlined ce-theme-icon">light_mode</span>
    </button>
</div>

<div class="ce-auth-page">

    @* ── Hero (desktop left) ── *@
    <div class="ce-auth-hero">
        <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:2.5rem;position:relative">
            <div style="width:46px;height:46px;background:rgba(255,255,255,.2);border-radius:12px;display:flex;align-items:center;justify-content:center;color:#fff">
                <span class="material-symbols-outlined" style="font-size:26px">school</span>
            </div>
            <div>
                <div style="font-size:1.2rem;font-weight:800">CampusEvents</div>
                <div style="font-size:.73rem;opacity:.75">Trường Đại học ABC</div>
            </div>
        </div>

        @* Feature card *@
        <div style="background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.2);border-radius:16px;padding:1.4rem;max-width:360px;backdrop-filter:blur(6px);position:relative">
            <div style="font-size:.72rem;opacity:.75;text-transform:uppercase;letter-spacing:.08em;font-weight:600;margin-bottom:.65rem">Sự kiện nổi bật</div>
            <div style="font-size:1.15rem;font-weight:800;margin-bottom:.4rem">Tech Symposium 2025</div>
            <div style="font-size:.82rem;opacity:.8;margin-bottom:.875rem">Thứ Sáu, 21/03 · Hội trường A</div>
            <div style="display:flex;align-items:center;gap:.5rem">
                <div style="display:flex">
                    @foreach (var c in new[]{"#ef4444","#3b82f6","#22c55e","#f59e0b"}) {
                    <div style="width:22px;height:22px;border-radius:50%;background:@c;border:2px solid rgba(255,255,255,.3);margin-right:-7px"></div>
                    }
                </div>
                <span style="font-size:.78rem;opacity:.85;margin-left:.7rem">+158 đã đăng ký</span>
            </div>
            @* Floating badge *@
            <div style="position:absolute;top:-14px;right:-10px;background:rgba(255,255,255,.95);border-radius:10px;padding:.4rem .75rem;color:#0f172a;font-size:.75rem;font-weight:700;display:flex;align-items:center;gap:.35rem;box-shadow:0 6px 20px rgba(0,0,0,.18)">
                <span class="material-symbols-outlined" style="font-size:14px;color:#22c55e">check_circle</span> Đăng ký ngay!
            </div>
        </div>

        <p style="position:relative;margin-top:2.5rem;font-size:1rem;font-weight:600;opacity:.88;max-width:320px;text-align:center;line-height:1.6">
            Khám phá, đăng ký và theo dõi tất cả sự kiện trường ngay tại một nơi.
        </p>

        @* Desktop theme toggle *@
        <button data-action="toggle-theme"
                style="position:absolute;top:1rem;right:1rem;background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.25);border-radius:8px;padding:.38rem;cursor:pointer;color:#fff;display:flex;align-items:center">
            <span class="material-symbols-outlined ce-theme-icon" style="font-size:19px">light_mode</span>
        </button>
    </div>

    @* ── Form column ── *@
    <div class="ce-auth-form-col">
        <div class="ce-auth-card">

            @* Tabs *@
            <div class="ce-tabs ce-tabs-wrapper mb-4" style="border-bottom:2px solid var(--border)">
                <button class="ce-tab-btn active" data-tab="tab-login"    style="font-size:.95rem;padding:.65rem 1.25rem">Đăng nhập</button>
                <button class="ce-tab-btn"        data-tab="tab-register" style="font-size:.95rem;padding:.65rem 1.25rem">Đăng ký</button>
            </div>

            @* LOGIN *@
            <div class="ce-tab-pane active" id="tab-login">
                <div class="ce-auth-title">Chào mừng trở lại!</div>
                <div class="ce-auth-sub">Đăng nhập bằng tài khoản sinh viên của bạn</div>

                @using (Html.BeginForm("Login", "Account", FormMethod.Post)) {
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="ce-form-label">Mã sinh viên / Email</label>
                        <div class="ce-input-icon">
                            <span class="material-symbols-outlined icon">badge</span>
                            <input class="ce-form-control" name="username" type="text"
                                   placeholder="SV2021001234 hoặc email@student.abc.edu.vn" />
                        </div>
                    </div>
                    <div class="mb-2">
                        <label class="ce-form-label">Mật khẩu</label>
                        <div class="ce-input-icon">
                            <span class="material-symbols-outlined icon">lock</span>
                            <input class="ce-form-control" name="password" type="password"
                                   id="pw-login" placeholder="••••••••"
                                   style="padding-right:2.8rem" />
                            <button type="button" onclick="cePwToggle('pw-login',this)"
                                    style="position:absolute;right:.7rem;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:var(--text-muted)">
                                <span class="material-symbols-outlined" style="font-size:17px">visibility</span>
                            </button>
                        </div>
                    </div>
                    <div class="d-flex justify-content-end mb-4">
                        <a href="#" style="font-size:.78rem;color:var(--primary)">Quên mật khẩu?</a>
                    </div>
                    <button class="ce-btn ce-btn-primary ce-btn-block ce-btn-lg mb-3" type="submit">
                        <span class="material-symbols-outlined">login</span> Đăng nhập
                    </button>
                }

                <div class="ce-auth-divider">hoặc</div>
                <button class="ce-btn ce-btn-ghost ce-btn-block ce-btn-lg" style="justify-content:center;gap:.6rem" type="button">
                    <svg width="17" height="17" viewBox="0 0 48 48"><path fill="#EA4335" d="M24 9.5c3.5 0 6.6 1.2 9.1 3.2l6.8-6.8C35.7 2.3 30.2 0 24 0 14.6 0 6.6 5.5 2.8 13.5l7.9 6.1C12.5 13.2 17.8 9.5 24 9.5z"/><path fill="#4285F4" d="M46.5 24.5c0-1.6-.1-3.1-.4-4.5H24v8.5h12.7c-.6 2.9-2.3 5.3-4.8 7l7.6 5.9c4.5-4.1 7-10.2 7-16.9z"/><path fill="#FBBC05" d="M10.7 28.4A14.5 14.5 0 0 1 9.5 24c0-1.5.3-3 .7-4.4l-7.9-6.1A23.8 23.8 0 0 0 0 24c0 3.9.9 7.5 2.8 10.7l7.9-6.3z"/><path fill="#34A853" d="M24 48c6.2 0 11.4-2 15.2-5.5l-7.6-5.9c-2 1.4-4.7 2.2-7.6 2.2-6.2 0-11.5-3.7-13.3-9.9l-7.9 6.3C6.6 42.5 14.6 48 24 48z"/></svg>
                    Tiếp tục với Google (SSO Trường)
                </button>
            </div>

            @* REGISTER *@
            <div class="ce-tab-pane" id="tab-register">
                <div class="ce-auth-title">Tạo tài khoản</div>
                <div class="ce-auth-sub">Đăng ký với thông tin sinh viên của bạn</div>

                @using (Html.BeginForm("Register", "Account", FormMethod.Post)) {
                    @Html.AntiForgeryToken()
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="ce-form-label">Họ</label>
                            <input class="ce-form-control" name="lastName"  type="text" placeholder="Nguyễn" />
                        </div>
                        <div class="col-6">
                            <label class="ce-form-label">Tên</label>
                            <input class="ce-form-control" name="firstName" type="text" placeholder="Bình" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="ce-form-label">Mã sinh viên</label>
                        <div class="ce-input-icon">
                            <span class="material-symbols-outlined icon">badge</span>
                            <input class="ce-form-control" name="studentId" type="text" placeholder="SV2021001234" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="ce-form-label">Email trường</label>
                        <div class="ce-input-icon">
                            <span class="material-symbols-outlined icon">mail</span>
                            <input class="ce-form-control" name="email" type="email" placeholder="tensv@student.abc.edu.vn" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="ce-form-label">Khoa / Ngành</label>
                        <select class="ce-form-select" name="faculty">
                            <option value="">Chọn khoa</option>
                            <option>Công nghệ Thông tin</option>
                            <option>Kinh tế</option>
                            <option>Kỹ thuật Điện</option>
                            <option>Ngoại ngữ</option>
                            <option>Quản trị Kinh doanh</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="ce-form-label">Mật khẩu</label>
                        <div class="ce-input-icon">
                            <span class="material-symbols-outlined icon">lock</span>
                            <input class="ce-form-control" name="password" type="password"
                                   id="pw-reg" placeholder="Tối thiểu 8 ký tự" style="padding-right:2.8rem" />
                            <button type="button" onclick="cePwToggle('pw-reg',this)"
                                    style="position:absolute;right:.7rem;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:var(--text-muted)">
                                <span class="material-symbols-outlined" style="font-size:17px">visibility</span>
                            </button>
                        </div>
                    </div>
                    <div class="mb-4">
                        <label style="display:flex;align-items:flex-start;gap:.45rem;cursor:pointer;font-size:.83rem;color:var(--text-muted)">
                            <input type="checkbox" style="margin-top:3px;accent-color:var(--primary);flex-shrink:0" />
                            Tôi đồng ý với <a href="#" style="color:var(--primary)">Điều khoản sử dụng</a> và <a href="#" style="color:var(--primary)">Chính sách bảo mật</a>
                        </label>
                    </div>
                    <button class="ce-btn ce-btn-primary ce-btn-block ce-btn-lg" type="submit">
                        <span class="material-symbols-outlined">person_add</span> Tạo tài khoản
                    </button>
                }
            </div>

        </div>
    </div>

</div>@* /ce-auth-page *@

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/Scripts/campus-app.js"></script>
<script>
    function cePwToggle(id, btn) {
        var inp = document.getElementById(id);
        var isText = inp.type === 'text';
        inp.type = isText ? 'password' : 'text';
        btn.querySelector('.material-symbols-outlined').textContent = isText ? 'visibility' : 'visibility_off';
    }
</script>
</body>
</html>
